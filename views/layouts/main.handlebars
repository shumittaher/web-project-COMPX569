<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Post App</title>
    <link rel="stylesheet" href="/public/css/style.css">
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
</head>

<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark p-3">
    <div class="container">
        <a class="navbar-brand" href="/">MyWebsite</a>

        <button class="navbar-toggler my-3" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link text-end" href="/">🏠 Home</a></li>
                {{#if user}}
                <li class="nav-item"><a class="nav-link text-end" href="/account/edit">✏️ Edit Profile</a></li>
                <li class="nav-item"><a class="nav-link text-end text-danger" href="/account/logout">🚪 Log out</a></li>
                {{else}}
                <li class="nav-item"><a class="nav-link text-end" href="/account/create">📝 Register</a></li>
                <li class="nav-item"><a class="nav-link text-end" href="/account/login">🔑 Log in</a></li>
                {{/if}}
            </ul>
        </div>
    </div>
</nav>

<main class="container-lg py-5 pt-sm-5">

    {{{body}}}

</main>

<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<script>

    const quill1 = new Quill('#newArticleForm .quilEditBox', {
        theme: 'snow',
    });

    const quill2 = new Quill('#editArticleForm .quilEditBox', {
        theme: 'snow',
    });

    const forms = document.querySelectorAll('form.input_form');
    forms.forEach((form) => {
        form.addEventListener('submit', (event) => {
            form.querySelector(' .quillTargetBox').value = form.querySelector('.quilEditBox .ql-editor').innerHTML
        })
    })
</script>
</body>
</html>
